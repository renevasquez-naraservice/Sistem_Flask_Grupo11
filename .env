# Configuración de Flask
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1

# Clave secreta (cambiar en producción)
SECRET_KEY=plantilla-secret-key-2026-desarrollo

# Base de datos - SQLite por defecto
# DATABASE_URL=sqlite:///instance/plantilla.db

# Para MySQL (descomentar si se usa)
DATABASE_URL=mysql+pymysql://root:@localhost:3306/db_restaurante
# Tenemos Database "db_restaurante" creada en MySQL antes de ejecutar la aplicación